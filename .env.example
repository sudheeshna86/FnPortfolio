# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Admin authentication password
# Use a strong password (20+ characters)
VITE_ADMIN_PASSWORD=admin1234567890

# Optional: Image upload configuration
# VITE_IMAGE_UPLOAD_PROVIDER=cloudinary
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_preset

# Optional: AI Chatbot API keys
# VITE_OPENAI_API_KEY=sk-...
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# Optional: Analytics
# VITE_SENTRY_DSN=https://...

# Optional: Database (if using database approach)
# DATABASE_URL=postgresql://user:password@host:port/database
# SQLITE_DB_PATH=./portfolio.db

# Optional: Development
# VITE_API_BASE_URL=http://localhost:5173/api
# DEBUG=true
